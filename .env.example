# DamgaPanel ortam değişkenleri — bu dosyayı .env olarak kopyalayıp doldurun.
# .env asla commit'lenmez (bkz. .gitignore).

# ——— Veritabanı (PostgreSQL) ———
# Yerelde docker-compose ile: kullanıcı=damga, şifre=damga, db=damgapanel
DATABASE_URL="postgresql://damga:damga@localhost:5432/damgapanel?schema=public"

# ——— Redis (BullMQ arka plan işleri) ———
REDIS_URL="redis://localhost:6379"

# ——— AI sağlayıcıları (mesaj/analiz üretimi) ———
# Aktif sağlayıcı: gemini | anthropic (UI /ayarlar'dan da değiştirilir)
AI_PROVIDER="gemini"
# Claude — console.anthropic.com (kredi gerekir)
ANTHROPIC_API_KEY="sk-ant-..."
# Gemini — aistudio.google.com/app/apikey (ücretsiz katman var)
GEMINI_API_KEY=""

# ——— Google API'leri ———
GOOGLE_PLACES_API_KEY=""
GOOGLE_PAGESPEED_API_KEY=""

# ——— Panel girişi (tek kullanıcı) ———
# Panele erişim için kullanıcı adı + şifre. Çerez AUTH_SECRET ile imzalanır.
# AUTH_SECRET'ı üretmek için: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_USER="damgabilisim"
AUTH_PASSWORD="123sifre123"
AUTH_SECRET="uzun-rastgele-gizli-anahtar-buraya"
